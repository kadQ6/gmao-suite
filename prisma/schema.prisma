  dateReforme           DateTime?
  motifReforme          String?
  remplacementPrevu     Boolean                    @default(false)
  budgetRemplacement    Decimal?                   @db.Decimal(12, 2)
  anneeRemplacement     Int?
  prioriteRenouvellement BiomedRenewalPriority     @default(NORMALE)
  decisionPar           String?
