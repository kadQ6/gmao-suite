  technicien       BiomedTechnician?    @relation(fields: [technicienId], references: [id], onDelete: SetNull)

  @@index([equipementId])
}

model BiomedQualityControl {
  id            String          @id @default(cuid())
  numeroCQ      String          @unique
  equipementId  String
  typeControle  BiomedCqType    @default(PERFORMANCE)
