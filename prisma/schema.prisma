  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  equipement            BiomedEquipment   @relation(fields: [equipementId], references: [id], onDelete: Cascade)
  protocole             BiomedProtocol?   @relation(fields: [protocoleId], references: [id], onDelete: SetNull)
  technicien            BiomedTechnician? @relation(fields: [technicienId], references: [id], onDelete: SetNull)

  @@index([equipementId])
  @@index([datePrevue])
  @@index([statut])
}

model BiomedCorrectiveMaintenance {
  id               String               @id @default(cuid())
  numeroMC         String               @unique
  diId             String?
  equipementId     String
  panneConstatee   String?
  diagnostic       String?
  causeRacine      BiomedMcRootCause?
  actionCorrective String?
  piecesChangeeJson Json?
  technicienId     String?
