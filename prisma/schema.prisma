  PREVENTIVE
  CURATIVE
  CONTROLE_QUALITE
  VERIFICATION
}

enum BiomedDocumentType {
  PV_MAINTENANCE
  RAPPORT_INTERVENTION
  FICHE_TECHNIQUE
  MANUEL
  CERTIFICAT
  CONTRAT
  FACTURE
  PHOTO
  PLAN
  RAPPORT_CQ
  AUTRE_DOC
}

model BiomedSite {
  id               String         @id @default(cuid())
  code             String         @unique
  nom              String
  typeEtablissement BiomedSiteKind @default(HOPITAL)
  adresse          String?
  ville            String?
  region           String?
  pays             String         @default("France")
  codePostal       String?
  latitude         Decimal?       @db.Decimal(10, 8)
  longitude        Decimal?       @db.Decimal(11, 8)
  contactNom       String?
  contactTel       String?
  contactEmail     String?
  telephone        String?
  actif            Boolean        @default(true)
  remarques        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  batiments        BiomedBuilding[]
  locaux           BiomedRoom[]
  equipements      BiomedEquipment[]
  demandes         BiomedInterventionRequest[]
  mouvementsStock  BiomedStockMovement[]
  plansInvest      BiomedInvestmentPlan[]
  piecesDetachees  BiomedSparePart[]
}

model BiomedBuilding {
  id         String   @id @default(cuid())
  code       String
  nom        String
  siteId     String
  remarques  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  site       BiomedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locaux     BiomedRoom[]

  @@unique([siteId, code])
  @@index([siteId])
}

model BiomedRoom {
  id               String         @id @default(cuid())
  code             String
  nom              String
  siteId           String
  batimentId       String?
  etage            String?
  service          String?
  unite            String?
  typeLocal        BiomedRoomKind @default(AUTRE_LOCAL)
  niveauCriticite  BiomedCritLevel @default(MOYEN)
  remarques        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  site             BiomedSite     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  batiment         BiomedBuilding? @relation(fields: [batimentId], references: [id], onDelete: SetNull)
  equipements      BiomedEquipment[]
  demandes         BiomedInterventionRequest[]

  @@unique([siteId, code])
  @@index([siteId])
}

model BiomedFamily {
  id               String          @id @default(cuid())
  code             String          @unique
  nom              String
  parentId         String?
  classeIEC        BiomedIecClass  @default(IEC_IIA)
  periodiciteDefaut BiomedMpPeriodicity @default(ANNUEL)
  dureeVieDefaut   Int             @default(10)
  description      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  parent           BiomedFamily?   @relation("BiomedFamilyTree", fields: [parentId], references: [id], onDelete: SetNull)
  sousFamilles     BiomedFamily[]  @relation("BiomedFamilyTree")
  equipements      BiomedEquipment[]
  protocoles       BiomedProtocol[]
  plansInvest      BiomedInvestmentPlan[]
}

model BiomedMaintenanceKit {
  id                     String        @id @default(cuid())
  code                   String        @unique
  designation            String
  typeEquipementConcerne String?
  marque                 String?
  modele                 String?
  frequenceUtilisation   BiomedMpPeriodicity?
  coutEstime             Decimal?      @db.Decimal(12, 2)
  actif                  Boolean       @default(true)
  observations           String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  pieces                 BiomedKitPart[]
  protocoles             BiomedProtocol[]
}

model BiomedSparePart {
  id                   String              @id @default(cuid())
  reference            String              @unique
  designation          String
  categorie            String?
  marqueCompatible     String?
  modeleCompatible     String?
  stockDisponible      Int                 @default(0)
  stockMinimum         Int                 @default(1)
  stockMaximum         Int                 @default(10)
  unite                String              @default("piece")
  prixUnitaire         Decimal?            @db.Decimal(12, 2)
  devise               String              @default("EUR")
  fournisseur          String?
  referenceFournisseur String?
  emplacementMagasin   String?
  siteId               String?
  delaiApprovisionJours Int?
  criticiteStock       BiomedCritLevel     @default(MOYEN)
  datePeremption       DateTime?
  actif                Boolean             @default(true)
  observations         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  site                 BiomedSite?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  kitPieces            BiomedKitPart[]
  mouvements           BiomedStockMovement[]
  achats               BiomedPurchaseRequest[]

  @@index([siteId])
}

model BiomedKitPart {
  id       String              @id @default(cuid())
  kitId    String
  pieceId  String
  quantite Int                 @default(1)
  kit      BiomedMaintenanceKit @relation(fields: [kitId], references: [id], onDelete: Cascade)
  piece    BiomedSparePart      @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@unique([kitId, pieceId])
}

model BiomedProtocol {
  id                          String                     @id @default(cuid())
  code                        String                     @unique
  designation                 String
  familleId                   String?
  marqueCompatible            String?
  modeleCompatible            String?
  typeMaintenance             BiomedProtocolMaintenanceKind @default(PREVENTIVE)
  frequence                   BiomedMpPeriodicity        @default(ANNUEL)
  operationsJson              Json?
  controleObligatoiresJson    Json?
  outillageJson               Json?
  kitMaintenanceId            String?
  piecesRecommandeesJson      Json?
  tempsStandardMinutes        Int                        @default(60)
  niveauTechnicienRequis      BiomedTechnicianLevel      @default(NIVEAU2)
  consignesSecuriteJson       Json?
  referencesDocumentairesJson Json?
  version                     String                     @default("1.0")
  actif                       Boolean                    @default(true)
  observations                String?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  famille                     BiomedFamily?              @relation(fields: [familleId], references: [id], onDelete: SetNull)
  kitMaintenance              BiomedMaintenanceKit?      @relation(fields: [kitMaintenanceId], references: [id], onDelete: SetNull)
  equipements                 BiomedEquipment[]
  maintenancesPreventives     BiomedPreventiveMaintenance[]
}

model BiomedTechnician {
  id                 String                   @id @default(cuid())
  matricule          String?                  @unique
  nom                String
  prenom             String
  specialite         BiomedTechnicianSpecialty @default(BIOMED)
  niveauQualification BiomedTechnicianLevel   @default(NIVEAU2)
  habilitations      Json?
  zoneIntervention   String?
  employeur          String?
  telephone          String?
  email              String?
  actif              Boolean                  @default(true)
  userId             String?
  remarques          String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User?                    @relation("BiomedTechnicianUser", fields: [userId], references: [id], onDelete: SetNull)
  demandes           BiomedInterventionRequest[]
  maintenancesPrev   BiomedPreventiveMaintenance[]
  maintenancesCur    BiomedCorrectiveMaintenance[]
  controlesQualite   BiomedQualityControl[]
}

model BiomedEquipment {
  id                   String                 @id @default(cuid())
  numeroGMAO           String                 @unique
  numeroInventaire     String?                @unique
  numeroSerie          String?
  codeBarreQR          String?
  designation          String
  familleId            String
  marque               String?
  modele               String?
  fabricant            String?
  fournisseur          String?
  distributeur         String?
  referenceInterne     String?
  classeIEC            BiomedIecClass         @default(IEC_IIA)
  criticite            BiomedCritLevel        @default(MOYEN)
  usageClinique        String?
  siteId               String
  localId              String?
  responsableId        String?
  dateAchat            DateTime?
  dateMiseEnService    DateTime?
  dateFinGarantie      DateTime?
  dureeVieEstimee      Int                    @default(10)
  anneeFabrication     Int?
  coutAchat            Decimal?               @db.Decimal(12, 2)
  valeurActuelle       Decimal?               @db.Decimal(12, 2)
  devise               String                 @default("EUR")
  sousGarantie         Boolean                @default(false)
  sousContrat          Boolean                @default(false)
  typeContrat          String?
  fournisseurContrat   String?
  dateDebutContrat     DateTime?
  dateFinContrat       DateTime?
  statut               BiomedEquipmentStatus  @default(EN_SERVICE)
  etatGeneral          BiomedEquipmentCondition @default(BON)
  protocoleId          String?
  periodiciteMP        BiomedMpPeriodicity    @default(ANNUEL)
  derniereMPDate       DateTime?
  prochaineMPDate      DateTime?
  dernierePanneDate    DateTime?
  prochainCQDate       DateTime?
  dernierCQDate        DateTime?
  nbrePannes           Int                    @default(0)
  nbreMP               Int                    @default(0)
  coutMaintenanceCumul Decimal?               @db.Decimal(12, 2) @default(0)
  tempsArretCumul      Decimal?               @db.Decimal(10, 2) @default(0)
  photoPath            String?
  manuelPath           String?
  observations         String?
  actif                Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  site                 BiomedSite             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  local                BiomedRoom?            @relation(fields: [localId], references: [id], onDelete: SetNull)
  famille              BiomedFamily           @relation(fields: [familleId], references: [id], onDelete: Restrict)
  protocole            BiomedProtocol?        @relation(fields: [protocoleId], references: [id], onDelete: SetNull)
  responsable          User?                  @relation("BiomedEquipmentResponsible", fields: [responsableId], references: [id], onDelete: SetNull)
  demandes             BiomedInterventionRequest[]
  maintenancesPrev     BiomedPreventiveMaintenance[]
  maintenancesCur      BiomedCorrectiveMaintenance[]
  controlesQualite     BiomedQualityControl[]
  mouvementsStock      BiomedStockMovement[]
  achats               BiomedPurchaseRequest[]
  immobilisations      BiomedAssetFreeze[]
  documents            BiomedDocument[]
  investmentPlansForReplacement BiomedInvestmentPlan[] @relation("BiomedInvPlanEquipment")

  @@index([siteId])
  @@index([statut])
  @@index([familleId])
}

model BiomedInterventionRequest {
  id                   String                   @id @default(cuid())
  numeroDI             String                   @unique
  dateCreation         DateTime                 @default(now())
  demandeurId          String?
  demandeurNom         String?
  demandeurService     String?
  demandeurTel         String?
  siteId               String
  localId              String?
  equipementId         String
  descriptionPanne     String
  niveauUrgence        BiomedInterventionUrgency @default(NORMAL)
  criticiteEquipement  BiomedCritLevel          @default(MOYEN)
  statut               BiomedDiStatus           @default(OUVERTE)
  technicienId         String?
  dateAffectation      DateTime?
  dateIntervention     DateTime?
  dateCloture          DateTime?
  tempsArretHeures     Decimal?                 @db.Decimal(8, 2)
  cause                String?
  diagnostic           String?
  actionRealisee       String?
  piecesUtiliseesJson  Json?
  coutTotal            Decimal?                 @db.Decimal(12, 2)
  coutMainOeuvre       Decimal?                 @db.Decimal(12, 2)
  coutPieces           Decimal?                 @db.Decimal(12, 2)
  validationFinale     Boolean                  @default(false)
  validePar            String?
  observations         String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  site                 BiomedSite               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  local                BiomedRoom?              @relation(fields: [localId], references: [id], onDelete: SetNull)
  equipement           BiomedEquipment          @relation(fields: [equipementId], references: [id], onDelete: Cascade)
  technicien           BiomedTechnician?        @relation(fields: [technicienId], references: [id], onDelete: SetNull)
  maintenancesCur      BiomedCorrectiveMaintenance[]

  @@index([statut])
  @@index([siteId])
  @@index([equipementId])
}

model BiomedPreventiveMaintenance {
  id                    String            @id @default(cuid())
  numeroMP              String            @unique
  equipementId          String
  protocoleId           String?
  frequence             BiomedMpPeriodicity?
