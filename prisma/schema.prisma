// =============================================
// PSA Rwanda Audit Module
// =============================================

enum PsaEquipmentStatus {
  FONCTIONNEL
  EN_PANNE
  EN_ATTENTE
  HORS_SERVICE
}

model PsaSite {
  id          String          @id @default(cuid())
  code        String          @unique
  nom         String
  localisation String?
  region      String?
  capaciteO2  String?
  description String?
  contactNom  String?
  contactTel  String?
  latitude    Decimal?        @db.Decimal(10, 8)
  longitude   Decimal?        @db.Decimal(11, 8)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  equipements PsaEquipment[]
}

model PsaEquipment {
  id                String             @id @default(cuid())
  code              String             @unique
  designation       String
  marque            String?
  modele            String?
  numeroSerie       String?
  type              String?
  siteId            String
  statut            PsaEquipmentStatus @default(FONCTIONNEL)
  dateMiseEnService DateTime?
  dateFinGarantie   DateTime?
  observation       String?
  photoUrl          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  site              PsaSite            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  maintenances      PsaMaintenance[]
  piecesBesoins     PsaPieceNeed[]
  actions           PsaAction[]

  @@index([siteId])
  @@index([statut])
}

model PsaMaintenance {
  id              String             @id @default(cuid())
  equipementId    String
  dateMaintenance DateTime
  type            String
  description     String
  technicien      String?
  dureeHeures     Decimal?           @db.Decimal(8, 2)
  resultat        String?
  piecesUtilisees String?
  kitMaintenance  String?
  coutTotal       Decimal?           @db.Decimal(12, 2)
  numeroPV        String?
  pvUrl           String?
  observations    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  equipement      PsaEquipment       @relation(fields: [equipementId], references: [id], onDelete: Cascade)

  @@index([equipementId])
  @@index([dateMaintenance])
}

model PsaPieceNeed {
  id            String       @id @default(cuid())
  equipementId  String
  designation   String
  reference     String?
  quantite      Int          @default(1)
  prixUnitaire  Decimal?     @db.Decimal(12, 2)
  devise        String       @default("EUR")
  fournisseur   String?
  urgence       Boolean      @default(false)
  enStock       Boolean      @default(false)
  commandee     Boolean      @default(false)
  observations  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  equipement    PsaEquipment @relation(fields: [equipementId], references: [id], onDelete: Cascade)

  @@index([equipementId])
}

enum PsaActionStatus {
  A_FAIRE
  EN_COURS
  TERMINE
  ANNULE
}

enum PsaActionPriority {
  CRITIQUE
  HAUTE
  NORMALE
  BASSE
}

model PsaAction {
  id            String            @id @default(cuid())
  equipementId  String
  designation   String
  description   String?
  priorite      PsaActionPriority @default(NORMALE)
  statut        PsaActionStatus   @default(A_FAIRE)
  coutEstime    Decimal?          @db.Decimal(12, 2)
  responsable   String?
  echeance      DateTime?
  observations  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  equipement    PsaEquipment      @relation(fields: [equipementId], references: [id], onDelete: Cascade)

  @@index([equipementId])
  @@index([statut])
}

