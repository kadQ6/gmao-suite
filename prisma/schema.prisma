generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  TECHNICIAN
  CLIENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  AT_RISK
  COMPLETED
  CANCELLED
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  ON_HOLD
  BLOCKED
  DONE
  OVERDUE
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertLevel {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum DocumentCategory {
  REPORT
  DELIVERABLE
  MEETING_NOTE
  PLANNING
  TECHNICAL
  INTERVENTION
  PHOTO
  OTHER
}

enum RemarkTab {
  OVERVIEW
  TASKS
  ASSETS
  WORK_ORDERS
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String
  role           Role              @default(TECHNICIAN)
  password       String?
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tasks          Task[]            @relation("TaskAssignee")
  projects       Project[]         @relation("ProjectOwner")
  workOrders     WorkOrder[]       @relation("WorkOrderAssignee")
  clientLinks    ClientUser[]
  projectMembers ProjectMember[]
  projectUpdates ProjectUpdate[]   @relation("ProjectUpdateAuthor")
  interventions  Intervention[]    @relation("InterventionAuthor")
  projectActions ProjectAction[]   @relation("ProjectActionAssignee")
  documents      ProjectDocument[] @relation("ProjectDocumentUploader")
  activityLogs   ActivityLog[]
  projectRemarks ProjectRemark[]   @relation("ProjectRemarkAuthor")
  passwordResetTokens PasswordResetToken[]
  gmaoImportTemplates GmaoImportTemplate[]
  gmaoImportBatches   GmaoImportBatch[]
}

model Project {
  id             String            @id @default(cuid())
  name           String
  code           String            @unique
  description    String?
  ownerId        String
  owner          User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  status         ProjectStatus     @default(ACTIVE)
  priority       ActionPriority    @default(MEDIUM)
  progress       Float             @default(0)
  country        String?
  site           String?
  type           String?
  budgetEstimate Decimal?          @db.Decimal(14, 2)
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tasks          Task[]
  assets         Asset[]
  workOrders     WorkOrder[]
  clients        ProjectClient[]
  members        ProjectMember[]
  updates        ProjectUpdate[]
  maintenance    MaintenancePlan[]
  interventions  Intervention[]
  actionPlans    ActionPlan[]
  projectActions ProjectAction[]
  milestones     Milestone[]
  documents      ProjectDocument[]
  alerts         Alert[]
  activityLogs   ActivityLog[]
  accessCodes    ClientPortalAccessCode[]
  remarks        ProjectRemark[]
  gmaoImportTemplates GmaoImportTemplate[]
  gmaoImportBatches   GmaoImportBatch[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  priority    Int        @default(2)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  archivedAt  DateTime?
  projectId   String
  assigneeId  String?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Asset {
  id             String              @id @default(cuid())
  code           String              @unique
  name           String
  category       String
  categoryId     String?
  categoryRef    EquipmentCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  location       String?
  site           String?
  status         String              @default("OPERATIONAL")
  model          String?
  manufacturer   String?
  serialNumber   String?
  criticality    ActionPriority      @default(MEDIUM)
  maintenanceCls String?
  purchaseDate   DateTime?
  installedAt    DateTime?
  archivedAt     DateTime?
  projectId      String?
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  visibleToClient Boolean            @default(true)
  workOrders     WorkOrder[]
  maintenance    MaintenancePlan[]
  interventions  Intervention[]
  alerts         Alert[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model WorkOrder {
  id              String          @id @default(cuid())
  reference       String          @unique
  title           String
  description     String?
  type            WorkOrderType
  status          WorkOrderStatus @default(OPEN)
  assetId         String
  projectId       String?
  assigneeId      String?
  scheduledFor    DateTime?
  completedAt     DateTime?
  visibleToClient Boolean         @default(true)
  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee        User?           @relation("WorkOrderAssignee", fields: [assigneeId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Client {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  country   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  users     ClientUser[]
  projects  ProjectClient[]
  accessCodes ClientPortalAccessCode[]
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
}

model ProjectClient {
  id        String   @id @default(cuid())
  projectId String
  clientId  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([projectId, clientId])
}

model ProjectMember {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  roleInProject String?
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectUpdate {
  id              String   @id @default(cuid())
  projectId       String
  title           String
  body            String
  visibleToClient Boolean  @default(true)
  createdById     String
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("ProjectUpdateAuthor", fields: [createdById], references: [id], onDelete: Cascade)
}

model EquipmentCategory {
  id        String  @id @default(cuid())
  name      String  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model MaintenancePlan {
  id             String   @id @default(cuid())
  projectId      String
  equipmentId    String
  periodicityDays Int
  checklist      String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment      Asset    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model Intervention {
  id              String       @id @default(cuid())
  projectId       String
  equipmentId     String
  type            WorkOrderType
  status          WorkOrderStatus @default(OPEN)
  plannedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  summary         String
  internalNotes   String?
  visibleToClient Boolean      @default(true)
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment       Asset        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdBy       User         @relation("InterventionAuthor", fields: [createdById], references: [id], onDelete: Cascade)
}

model ActionPlan {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      ActionStatus    @default(TODO)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions     ProjectAction[]
}

model ProjectAction {
  id              String         @id @default(cuid())
  actionPlanId    String
  projectId       String
  title           String
  description     String?
  status          ActionStatus   @default(TODO)
  priority        ActionPriority @default(MEDIUM)
  dueDate         DateTime?
  assigneeId      String?
  blockedReason   String?
  visibleToClient Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  actionPlan      ActionPlan     @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee        User?          @relation("ProjectActionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  alerts          Alert[]
}

model Milestone {
  id              String        @id @default(cuid())
  projectId       String
  title           String
  dueDate         DateTime?
  status          ActionStatus  @default(TODO)
  visibleToClient Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectDocument {
  id              String           @id @default(cuid())
  projectId       String
  category        DocumentCategory @default(OTHER)
  name            String
  storagePath     String
  mimeType        String?
  sizeBytes       Int?
  visibleToClient Boolean          @default(true)
  uploadedById    String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy      User             @relation("ProjectDocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
}

model Alert {
  id          String      @id @default(cuid())
  projectId   String
  equipmentId String?
  actionId    String?
  level       AlertLevel  @default(WARNING)
  message     String
  status      AlertStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment   Asset?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  action      ProjectAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  entity     String
  entityId   String?
  action     String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ClientPortalAccessCode {
  id          String   @id @default(cuid())
  code        String   @unique
  clientId    String
  projectId   String
  active      Boolean  @default(true)
  generatedBy String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([clientId, projectId])
  @@index([clientId, active])
  @@index([projectId, active])
}

model ProjectRemark {
  id          String    @id @default(cuid())
  projectId   String
  tab         RemarkTab
  body        String
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("ProjectRemarkAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId, tab, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt, usedAt])
}

enum GmaoImportType {
  EQUIPMENT_INVENTORY
  MAINTENANCE_PLAN
  SPARE_STOCK
  MAINTENANCE_KIT
  PURCHASE
  TECHNICIAN
  SITE
  HOSPITAL
  SUPPLIER
  SERVICE
}

enum GmaoImportBatchStatus {
  UPLOADED
  MAPPING
  VALIDATED
  PREVIEWED
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
  ABANDONED
}

enum GmaoImportRowStatus {
  PENDING
  VALID
  WARNING
  ERROR
  SKIPPED
  APPLIED
}

enum GmaoImportMode {
  CREATE_ONLY
  UPDATE_ONLY
  UPSERT
  MERGE
}

model GmaoImportTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  projectId   String?
  importType  GmaoImportType
  mappingJson Json
  dedupeKey   String?
  headerRow   Int            @default(1)
  defaultMode GmaoImportMode @default(UPSERT)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([importType])
}

model GmaoImportBatch {
  id                  String                @id @default(cuid())
  projectId           String
  importType          GmaoImportType
  status              GmaoImportBatchStatus @default(UPLOADED)
  fileName            String
  storagePath         String
  sheetName           String?
  headerRow           Int                   @default(1)
  mappingSnapshotJson Json?
  mode                GmaoImportMode        @default(UPSERT)
  dedupeStrategy      String?
  dryRun              Boolean               @default(false)
  statsJson           Json?
  createdById         String
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  project             Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy           User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  rows                GmaoImportRow[]

  @@index([projectId, createdAt])
  @@index([status])
}

model GmaoImportRow {
  id             String               @id @default(cuid())
  batchId        String
  rowIndex       Int
  rawJson        Json
  normalizedJson Json?
  status         GmaoImportRowStatus  @default(PENDING)
  errorCode      String?
  errorMessage   String?
  entityId       String?
  batch          GmaoImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowIndex])
  @@index([batchId, status])
}
